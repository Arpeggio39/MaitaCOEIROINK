{
  "name": "maita-coeiroink-shell",
  "version": "0.1.0",
  "description": "琵音マイタ専用の COEIROINK API ラッパー（Electron）",
  "main": "src/main/index.js",
  "author": "Arpeggio",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:mac:dir": "electron-builder --mac --dir",
    "dist:win": "electron-builder --win --x64",
    "dist:win:dir": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "jp.arpeggio.maita-coeiroink",
    "productName": "琵音マイタ for COEIROINK",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.music"
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "MaitaCOEIROINK"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "琵音マイタ for COEIROINK",
      "installerLanguages": [
        "ja_JP",
        "en_US"
      ],
      "language": "1041",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  }
}
