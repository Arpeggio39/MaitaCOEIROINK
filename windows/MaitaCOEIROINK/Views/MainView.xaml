<UserControl
    x:Class="MaitaCOEIROINK.Views.MainView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MaitaCOEIROINK.Models"
    xmlns:viewmodels="using:MaitaCOEIROINK.ViewModels"
    x:DataType="viewmodels:MainViewModel"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Padding="18,20,18,12" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="40" Height="40" CornerRadius="20"
                                Background="{ThemeResource AccentFillColorDefaultBrush}">
                            <FontIcon Glyph="&#xE8D4;" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontWeight="SemiBold" FontSize="15" Text="琵音マイタ" />
                            <TextBlock FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=" for COEIROINK" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Padding="14,0,14,10" Spacing="8">
                    <Button Content="＋ 新規プロジェクト" HorizontalAlignment="Stretch"
                            Command="{x:Bind NewProjectCommand}" />
                    <Button Content="読み上げ辞書" HorizontalAlignment="Stretch"
                            Command="{x:Bind OpenDictionaryCommand}" />
                </StackPanel>

                <ListView x:Name="ProjectList" Grid.Row="2" Padding="10,6"
                          ItemsSource="{x:Bind ProjectItems, Mode=OneWay}"
                          SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnProjectItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProjectListItem">
                            <Border Padding="12,8" CornerRadius="8"
                                    Background="{x:Bind IsActive, Converter={StaticResource ActiveProjectBrushConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                                   Text="{x:Bind Project.Title}" />
                                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Text="{x:Bind UpdatedLabel, Converter={StaticResource UpdatedLabelConverter}}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="×" VerticalAlignment="Top"
                                            Tag="{x:Bind Project.Id}" Click="OnDeleteProjectClick" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Grid x:Name="RootGrid" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                <Grid Padding="16,12" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock x:Name="TitleBlock" FontSize="20" FontWeight="SemiBold"
                                   Text="{x:Bind ProjectTitle, Mode=OneWay}"
                                   Tapped="OnTitleTapped" />
                        <TextBox x:Name="TitleBox"
                                 Visibility="{x:Bind IsTitleEditVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Text="{x:Bind TitleEditText, Mode=TwoWay}"
                                 LostFocus="OnTitleLostFocus" KeyDown="OnTitleKeyDown" />
                    </StackPanel>

                    <ProgressBar x:Name="WaveformBar" Grid.Column="1" Height="22" Maximum="100" IsIndeterminate="True"
                                 Visibility="{x:Bind IsPlaying, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                 VerticalAlignment="Center" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button ToolTipService.ToolTip="再生/停止" Command="{x:Bind TogglePlaybackCommand}">
                            <FontIcon Glyph="{x:Bind IsPlaying, Mode=OneWay, Converter={StaticResource PlayStopGlyphConverter}}" />
                        </Button>
                        <Button ToolTipService.ToolTip="書き出し（WAV）" Command="{x:Bind ExportAllCommand}">
                            <FontIcon Glyph="&#xE898;" />
                        </Button>
                        <ComboBox Width="88" ItemsSource="{x:Bind SampleRateOptions, Mode=OneWay}"
                                  SelectedIndex="{x:Bind ExportSamplingRateIndex, Mode=TwoWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="16,12,8,8">
                        <ScrollViewer x:Name="MirrorScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      IsHitTestVisible="False">
                            <TextBlock x:Name="SegmentMirror" TextWrapping="Wrap" Padding="12,10" FontFamily="Segoe UI" FontSize="14" LineHeight="22" />
                        </ScrollViewer>
                        <ScrollViewer x:Name="EditorScroll" VerticalScrollBarVisibility="Auto" ViewChanged="OnEditorScrollChanged">
                            <TextBox x:Name="Editor" AcceptsReturn="True" TextWrapping="Wrap"
                                     PlaceholderText="ここに台本を入力…"
                                     Background="Transparent" BorderThickness="0"
                                     Padding="12,10" FontSize="14"
                                     TextChanging="OnEditorTextChanging"
                                     SelectionChanged="OnEditorSelectionChanged" />
                        </ScrollViewer>
                    </Grid>

                    <Border Grid.Row="1" Margin="16,0,8,12" Padding="12,10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8"
                            Visibility="{x:Bind IsIntonationVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" HorizontalAlignment="Left" Style="{StaticResource AccentButtonStyle}"
                                    Content="韻律を再取得" Command="{x:Bind RegenerateProsodyCommand}" />
                            <ScrollViewer x:Name="IntonationTextScroll" Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled" ViewChanged="OnIntonationScrollChanged" />
                            <ScrollViewer x:Name="IntonationSliderScroll" Grid.Row="2" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled" Height="120" ViewChanged="OnIntonationSliderScrollChanged" />
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Column="1"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1,0,0,0"
                        Visibility="{x:Bind IsParamPaneVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ScrollViewer Padding="20,18,20,24">
                        <StackPanel Spacing="16">
                            <Button Content="この文章を書き出し" HorizontalAlignment="Stretch"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Command="{x:Bind ExportActiveSentenceCommand}" />

                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="話速" />
                                    <TextBlock HorizontalAlignment="Right" Text="{x:Bind SpeedScaleLabel, Mode=OneWay}" />
                                </Grid>
                                <Slider Minimum="0.5" Maximum="2" StepFrequency="0.01" Value="{x:Bind SpeedScale, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="声の高さ" />
                                    <TextBlock HorizontalAlignment="Right" Text="{x:Bind PitchScaleLabel, Mode=OneWay}" />
                                </Grid>
                                <Slider Minimum="-0.15" Maximum="0.15" StepFrequency="0.01" Value="{x:Bind PitchScale, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Text="ピッチ加工" />
                                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{x:Bind ProcessingAlgorithms, Mode=OneWay}"
                                          SelectedItem="{x:Bind ProcessingAlgorithm, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="抑揚" />
                                    <TextBlock HorizontalAlignment="Right" Text="{x:Bind IntonationScaleLabel, Mode=OneWay}" />
                                </Grid>
                                <Slider Minimum="0" Maximum="2" StepFrequency="0.01" Value="{x:Bind IntonationScale, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="音量" />
                                    <TextBlock HorizontalAlignment="Right" Text="{x:Bind VolumeScaleLabel, Mode=OneWay}" />
                                </Grid>
                                <Slider Minimum="0" Maximum="2" StepFrequency="0.01" Value="{x:Bind VolumeScale, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="開始無音" />
                                    <TextBlock HorizontalAlignment="Right" Text="{x:Bind PrePhonemeLabel, Mode=OneWay}" />
                                </Grid>
                                <Slider Minimum="0" Maximum="1" StepFrequency="0.01" Value="{x:Bind PrePhonemeLength, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="終了無音" />
                                    <TextBlock HorizontalAlignment="Right" Text="{x:Bind PostPhonemeLabel, Mode=OneWay}" />
                                </Grid>
                                <Slider Minimum="0" Maximum="1" StepFrequency="0.01" Value="{x:Bind PostPhonemeLength, Mode=TwoWay}" />
                            </StackPanel>

                            <Button Content="既定値に戻す" HorizontalAlignment="Stretch"
                                    Command="{x:Bind ResetSegmentParamsCommand}" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,24"
                Padding="14,10" CornerRadius="8"
                Background="{ThemeResource SystemFillColorSolidNeutralBackground}"
                Visibility="{x:Bind IsToastVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{x:Bind ToastMessage, Mode=OneWay}" />
        </Border>

        <ProgressRing Grid.ColumnSpan="2" Width="48" Height="48" IsActive="{x:Bind IsBusy, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="{x:Bind IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
    </Grid>
</UserControl>
