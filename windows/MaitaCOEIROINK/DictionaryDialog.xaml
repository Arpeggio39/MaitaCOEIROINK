<ContentDialog
    x:Class="MaitaCOEIROINK.DictionaryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="読み上げ辞書"
    PrimaryButtonText="保存"
    CloseButtonText="閉じる"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryClick">

    <ContentDialog.Resources>
        <helpers:MoraCountConverter x:Key="MoraCountConverter" xmlns:helpers="using:MaitaCOEIROINK.Helpers" />
    </ContentDialog.Resources>

    <Grid MinWidth="640" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" MaxHeight="420" VerticalScrollBarVisibility="Auto">
            <ListView x:Name="EntriesList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:DictionaryEntry" xmlns:models="using:MaitaCOEIROINK.Models">
                        <Grid ColumnSpacing="8" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" PlaceholderText="単語" Text="{Binding Word, Mode=TwoWay}" />
                            <TextBox Grid.Column="1" PlaceholderText="読み（かな）" Text="{Binding Yomi, Mode=TwoWay}" />
                            <NumberBox Grid.Column="2" Minimum="0" SpinButtonPlacementMode="Inline"
                                       Value="{Binding Accent, Mode=TwoWay}" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{Binding Yomi, Converter={StaticResource MoraCountConverter}}" />
                            <Button Grid.Column="4" Content="×" Tag="{Binding}" Click="OnDeleteRow" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

        <Button Grid.Row="1" HorizontalAlignment="Left" Content="＋ 行を追加" Click="OnAddRow" />
    </Grid>
</ContentDialog>
