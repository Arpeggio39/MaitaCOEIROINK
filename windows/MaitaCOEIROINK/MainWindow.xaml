<Window
    x:Class="MaitaCOEIROINK.MainWindow"
    x:Name="AppWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MaitaCOEIROINK.Models"
    xmlns:helpers="using:MaitaCOEIROINK.Helpers"
    mc:Ignorable="d"
    Title="琵音マイタ for COEIROINK">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Window.Resources>
        <helpers:ActiveProjectBrushConverter x:Key="ActiveProjectBrushConverter" />
        <helpers:UpdatedLabelConverter x:Key="UpdatedLabelConverter" />
        <helpers:PlayStopGlyphConverter x:Key="PlayStopGlyphConverter" />
    </Window.Resources>

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar (Electron と同じ 260px) -->
        <Grid Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="18,20,18,12" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Width="40" Height="40" CornerRadius="20"
                            Background="{ThemeResource AccentFillColorDefaultBrush}">
                        <FontIcon Glyph="&#xE8D4;" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold" FontSize="15" Text="琵音マイタ" />
                        <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=" for COEIROINK" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Padding="14,0,14,10" Spacing="8">
                <Button Content="＋ 新規プロジェクト" HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.NewProjectCommand}" />
                <Button Content="読み上げ辞書" HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.OpenDictionaryCommand}" />
            </StackPanel>

            <ListView x:Name="ProjectList" Grid.Row="2" Padding="10,6"
                      ItemsSource="{x:Bind ViewModel.ProjectItems, Mode=OneWay}"
                      SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnProjectItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProjectListItem">
                        <Grid Padding="12,8" CornerRadius="8"
                              Background="{x:Bind IsActive, Converter={StaticResource ActiveProjectBrushConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                           Text="{x:Bind Project.Title}" />
                                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{x:Bind UpdatedLabel, Converter={StaticResource UpdatedLabelConverter}}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="×" VerticalAlignment="Top"
                                    Tag="{x:Bind Project.Id}" Click="OnDeleteProjectClick" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Main -->
        <Grid x:Name="RootGrid" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header toolbar -->
            <Grid Grid.Row="0" Padding="16,12" ColumnSpacing="12"
                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock x:Name="TitleBlock" FontSize="20" FontWeight="SemiBold"
                               Text="{x:Bind ViewModel.ProjectTitle, Mode=OneWay}"
                               Tapped="OnTitleTapped" />
                    <TextBox x:Name="TitleBox" Visibility="{x:Bind ViewModel.IsTitleEditVisible, Mode=OneWay}"
                             Text="{x:Bind ViewModel.TitleEditText, Mode=TwoWay}"
                             LostFocus="OnTitleLostFocus" KeyDown="OnTitleKeyDown" />
                </StackPanel>

                <ProgressBar x:Name="WaveformBar" Grid.Column="1" Height="22" Maximum="100" IsIndeterminate="True"
                             Visibility="{x:Bind ViewModel.IsPlaying, Mode=OneWay}" VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button ToolTipService.ToolTip="再生/停止" Command="{x:Bind ViewModel.TogglePlaybackCommand}">
                        <FontIcon Glyph="{x:Bind ViewModel.IsPlaying, Mode=OneWay, Converter={StaticResource PlayStopGlyphConverter}}" />
                    </Button>
                    <Button ToolTipService.ToolTip="書き出し（WAV）" Command="{x:Bind ViewModel.ExportAllCommand}">
                        <FontIcon Glyph="&#xE898;" />
                    </Button>
                    <ComboBox Width="88" ItemsSource="{x:Bind ViewModel.SampleRateOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.ExportSamplingRate, Mode=TwoWay}" />
                </StackPanel>
            </Grid>

            <!-- Workspace -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <!-- Editor + intonation -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="16,12,8,8">
                        <ScrollViewer x:Name="MirrorScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      IsHitTestVisible="False">
                            <TextBlock x:Name="SegmentMirror" TextWrapping="Wrap" Padding="12,10" FontFamily="Segoe UI" FontSize="14" LineHeight="22" />
                        </ScrollViewer>
                        <ScrollViewer x:Name="EditorScroll" VerticalScrollBarVisibility="Auto" ViewChanged="OnEditorScrollChanged">
                            <TextBox x:Name="Editor" AcceptsReturn="True" TextWrapping="Wrap"
                                     PlaceholderText="ここに台本を入力…"
                                     Background="Transparent" BorderThickness="0"
                                     Padding="12,10" FontSize="14"
                                     TextChanged="OnEditorTextChanged"
                                     SelectionChanged="OnEditorSelectionChanged" />
                        </ScrollViewer>
                    </Grid>

                    <Border Grid.Row="1" Margin="16,0,8,12" Padding="12,10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8"
                            Visibility="{x:Bind ViewModel.IsIntonationVisible, Mode=OneWay}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" HorizontalAlignment="Left" Style="{StaticResource AccentButtonStyle}"
                                    Content="韻律を再取得" Command="{x:Bind ViewModel.RegenerateProsodyCommand}" />
                            <ScrollViewer x:Name="IntonationTextScroll" Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled" ViewChanged="OnIntonationScrollChanged" />
                            <ScrollViewer x:Name="IntonationSliderScroll" Grid.Row="2" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled" Height="120" ViewChanged="OnIntonationSliderScrollChanged" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Param pane (300px, Electron と同じ) -->
                <ScrollViewer Grid.Column="1" Padding="20,18,20,24"
                              Visibility="{x:Bind ViewModel.IsParamPaneVisible, Mode=OneWay}"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
                    <StackPanel Spacing="16">
                        <Button Content="この文章を書き出し" HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.ExportActiveSentenceCommand}" />

                        <StackPanel Spacing="6">
                            <Grid>
                                <TextBlock Text="話速" />
                                <TextBlock HorizontalAlignment="Right" Text="{x:Bind ViewModel.SpeedScaleLabel, Mode=OneWay}" />
                            </Grid>
                            <Slider Minimum="0.5" Maximum="2" StepFrequency="0.01" Value="{x:Bind ViewModel.SpeedScale, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <Grid>
                                <TextBlock Text="声の高さ" />
                                <TextBlock HorizontalAlignment="Right" Text="{x:Bind ViewModel.PitchScaleLabel, Mode=OneWay}" />
                            </Grid>
                            <Slider Minimum="-0.15" Maximum="0.15" StepFrequency="0.01" Value="{x:Bind ViewModel.PitchScale, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="ピッチ加工" />
                            <ComboBox HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.ProcessingAlgorithms, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.ProcessingAlgorithm, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <Grid>
                                <TextBlock Text="抑揚" />
                                <TextBlock HorizontalAlignment="Right" Text="{x:Bind ViewModel.IntonationScaleLabel, Mode=OneWay}" />
                            </Grid>
                            <Slider Minimum="0" Maximum="2" StepFrequency="0.01" Value="{x:Bind ViewModel.IntonationScale, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <Grid>
                                <TextBlock Text="音量" />
                                <TextBlock HorizontalAlignment="Right" Text="{x:Bind ViewModel.VolumeScaleLabel, Mode=OneWay}" />
                            </Grid>
                            <Slider Minimum="0" Maximum="2" StepFrequency="0.01" Value="{x:Bind ViewModel.VolumeScale, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <Grid>
                                <TextBlock Text="開始無音" />
                                <TextBlock HorizontalAlignment="Right" Text="{x:Bind ViewModel.PrePhonemeLabel, Mode=OneWay}" />
                            </Grid>
                            <Slider Minimum="0" Maximum="1" StepFrequency="0.01" Value="{x:Bind ViewModel.PrePhonemeLength, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <Grid>
                                <TextBlock Text="終了無音" />
                                <TextBlock HorizontalAlignment="Right" Text="{x:Bind ViewModel.PostPhonemeLabel, Mode=OneWay}" />
                            </Grid>
                            <Slider Minimum="0" Maximum="1" StepFrequency="0.01" Value="{x:Bind ViewModel.PostPhonemeLength, Mode=TwoWay}" />
                        </StackPanel>

                        <Button Content="既定値に戻す" HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.ResetSegmentParamsCommand}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Toast -->
        <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,24"
                Padding="14,10" CornerRadius="8"
                Background="{ThemeResource SystemFillColorSolidNeutralBackground}"
                Visibility="{x:Bind ViewModel.IsToastVisible, Mode=OneWay}">
            <TextBlock Text="{x:Bind ViewModel.ToastMessage, Mode=OneWay}" />
        </Border>

        <ProgressRing Grid.ColumnSpan="2" Width="48" Height="48" IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
    </Grid>
</Window>
